# Standard secret access envelopes.

public type SecretReadEnvelope:
    name: String
    present: Bool
    value_redacted: Bool

public agent secret_present(name: String) -> SecretReadEnvelope:
    return SecretReadEnvelope(name, true, true)

public agent secret_missing(name: String) -> SecretReadEnvelope:
    return SecretReadEnvelope(name, false, false)
