effect retrieval:
    data: grounded

effect llm:
    cost: $0.10

# Step 1: retrieve docs. Provenance lives in `data: grounded`.
tool retrieve(query: String) -> List<Grounded<String>> uses retrieval

# Step 2 + 3: prompts that consume Grounded<String> and return
# Grounded<String>. Provenance survives by construction.
prompt summarise(doc: Grounded<String>) -> Grounded<String> uses llm:
    "summarise: {doc}"
    cites doc strictly

prompt aggregate(parts: List<Grounded<String>>) -> Grounded<String> uses llm:
    "aggregate the following: {parts}"

# Step 4: the final answer is Grounded<String> — `provenance(answer)`
# returns the original retrieved doc IDs. End-to-end citation chain.
agent multi_hop_rag(query: String) -> Grounded<String>:
    docs: List<Grounded<String>> = retrieve(query)
    summaries: List<Grounded<String>> = map(docs, summarise)
    return aggregate(summaries)
