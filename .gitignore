# Rust
/target
**/target
# Cargo.lock is committed: corvid-cli is a binary crate and CI builds use
# `cargo build --locked` for reproducibility. The default `cargo new --lib`
# excludes Cargo.lock; that default does not apply to binary workspaces.

# Editor / OS
.DS_Store
.vscode/
.idea/
.claude/
*.swp
*.swo

# Corvid generated output (in user projects)
**/target/py/
**/target/wasm/
**/target/trace/

# Benchmark generated files
benches/corvid/generated/

# Snapshot test pending
**/*.snap.new

# MSVC object files leaked from cdylib_emission tests by cl.exe
crates/corvid-codegen-cl/*.obj
crates/corvid-cli/*.obj

# cdylib_catalog_demo C-host build outputs + runtime trace dumps
examples/cdylib_catalog_demo/host_c/*.exe
examples/cdylib_catalog_demo/trace_output/

# Phase 23-F browser CI test dependencies (Playwright + browsers
# install per-runner; not committed).
examples/wasm_browser_demo/test/node_modules/
examples/wasm_browser_demo/test/test-results/
examples/wasm_browser_demo/test/playwright-report/
examples/wasm_browser_demo/test/package-lock.json

# Phase 33-N moat-benchmark deps (npm + pip install per-runner /
# per-developer; not committed).
benches/moat/compile_time_rejection/node_modules/
benches/moat/compile_time_rejection/package-lock.json

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Secrets / local config
.env
.env.*
!.env.example
