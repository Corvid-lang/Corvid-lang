import "./std/jobs" use JobInputEnvelope, JobOutputEnvelope, JobRetryPolicy, JobStateEnvelope, job_input, job_output, retry_policy, retry_policy_valid, pending_job_state, job_needs_approval, job_metadata_redacted
import "./std/effects" use EffectEnvelope, effect_envelope, replay_safe, approval_required
import "./std/agent" use PlanStep, ActionRequest, ReviewVerdict, plan_step, action_request, review_verdict
import "./std/auth" use Actor, SessionRef, ApiKeyRef, AuthTraceContext, AuthDecision, user_actor, service_actor, session_ref, api_key_ref, auth_trace_for_session, auth_trace_for_api_key, allow_permission, deny_permission, session_active, api_key_active, auth_trace_same_tenant
import "./std/approvals" use ApprovalContractRef, ApprovalQueueItem, ApprovalAuditEnvelope, approval_contract_ref, approval_queue_item, approval_audit_envelope, approval_pending, approval_same_tenant, approval_not_expired, approval_redacted

effect inbox_read:
    cost: $0.04
    trust: workspace
    data: private

effect calendar_read:
    cost: $0.03
    trust: workspace
    data: private

effect executive_llm:
    cost: $0.35
    trust: bounded
    data: private

effect send_email:
    cost: $0.02
    trust: human_required
    data: external

effect task_write:
    cost: $0.01
    trust: workspace
    data: private

public type ExecutiveJobContract:
    job_kind: String
    queue_name: String
    input_schema: String
    output_schema: String
    max_attempts: Int
    budget_usd: Float
    approval_label: String
    needs_review: Bool
    idempotency_key: String
    replay_key: String

public type ExecutiveJobRun:
    contract: ExecutiveJobContract
    state: JobStateEnvelope
    input: JobInputEnvelope
    output: JobOutputEnvelope
    retry_plan: JobRetryPolicy
    effect_meta: EffectEnvelope
    plan: PlanStep
    action: ActionRequest
    review: ReviewVerdict

public type LoginRequest:
    tenant_id: String
    actor_id: String
    display_name: String
    session_id: String
    csrf_binding_id: String
    trace_id: String

public type ApiKeyLoginRequest:
    tenant_id: String
    service_actor_id: String
    display_name: String
    api_key_id: String
    trace_id: String

public type LoginResponse:
    actor: Actor
    session_ref: SessionRef
    trace: AuthTraceContext
    decision: AuthDecision
    status: String

public type ApiKeyLoginResponse:
    actor: Actor
    api_key: ApiKeyRef
    trace: AuthTraceContext
    decision: AuthDecision
    status: String

public type AuthStatusResponse:
    actor: Actor
    tenant_id: String
    authenticated: Bool
    permission: String
    reason: String
    replay_key: String

public type FollowUpSendRequest:
    tenant_id: String
    actor_id: String
    thread_id: String
    recipient: String
    body_fingerprint: String
    approval_id: String
    trace_id: String

public type FollowUpSendReceipt:
    message_id: String
    tenant_id: String
    thread_id: String
    approval_id: String
    trace_id: String
    status: String

public type ExecutiveApprovalProduct:
    approval: ApprovalQueueItem
    audit: ApprovalAuditEnvelope
    action: ActionRequest
    review: ReviewVerdict
    tenant_safe: Bool
    auditable: Bool
    ready_to_execute: Bool

