public @replayable
agent executive_schema_manifest() -> ExecutiveSchemaManifest:
    return ExecutiveSchemaManifest("personal_executive_agent", 5, 10, 5, 4, 5, "mock")

server personal_executive_agent_api:
    route GET "/schema" -> json ExecutiveSchemaManifest:
        return executive_schema_manifest()
    route GET "/schema/tenant" -> json ExecutiveTenant:
        return demo_tenant()
    route GET "/schema/user" -> json ExecutiveUserProfile:
        return demo_user_profile()
    route GET "/schema/inbox-thread" -> json ExecutiveInboxThread:
        return demo_inbox_thread()
    route GET "/schema/draft-reply" -> json ExecutiveDraftReply:
        return demo_draft_reply()
    route GET "/schema/calendar-event" -> json ExecutiveCalendarEvent:
        return demo_calendar_event()
    route GET "/schema/meeting-prep" -> json ExecutiveMeetingPrepPacket:
        return demo_meeting_prep_packet()
    route GET "/schema/daily-brief" -> json ExecutiveDailyBrief:
        return demo_daily_brief()
    route GET "/schema/task" -> json ExecutiveTaskItem:
        return demo_task_item()
    route GET "/schema/follow-up" -> json ExecutiveFollowUpItem:
        return demo_follow_up_item()
    route POST "/auth/session/login" body LoginRequest -> json LoginResponse:
        return session_login(body)
    route POST "/auth/api-key/login" body ApiKeyLoginRequest -> json ApiKeyLoginResponse:
        return api_key_login(body)
    route GET "/auth/status" -> json AuthStatusResponse:
        return auth_status("user-1", "tenant-1", "trace-auth-status")
    route GET "/auth/api-key/status" -> json AuthStatusResponse:
        return api_key_auth_status("service-1", "tenant-1", "trace-api-key-status")
    route GET "/approvals/follow-up" -> json ExecutiveApprovalProduct:
        auth = auth_status("user-1", "tenant-1", "trace-approval-open")
        return follow_up_approval_product(auth, "thread-1", "trace-approval-open")
    route POST "/actions/follow-up/send" body FollowUpSendRequest -> json FollowUpSendReceipt uses send_email:
        return execute_approved_follow_up(body)

schedule "0 7 * * 1-5" zone "America/New_York" -> daily_brief_job("active_users", "business_day") uses inbox_read, calendar_read, executive_llm
schedule "0 6 * * 1-5" zone "America/New_York" -> meeting_prep_job("active_users", "business_day") uses inbox_read, calendar_read, executive_llm
schedule "*/10 8-18 * * 1-5" zone "America/New_York" -> email_triage_job("active_users", "workday_window") uses inbox_read, executive_llm, task_write
schedule "*/15 8-18 * * 1-5" zone "America/New_York" -> follow_up_job("active_users", "open_threads") uses inbox_read, executive_llm, send_email, task_write

agent main() -> Bool:
    brief = daily_brief_job("user-1", "2026-04-29")
    prep = meeting_prep_job("user-1", "2026-04-29")
    triage = email_triage_job("user-1", "2026-04-29T08:00")
    follow = follow_up_job("user-1", "thread-1")
    auth = auth_status("user-1", "tenant-1", "trace-main-auth")
    service_auth = api_key_auth_status("service-1", "tenant-1", "trace-main-api-key")
    approval_product = follow_up_approval_product(auth, "thread-1", "trace-main-approval")
    return executive_job_contract_valid(brief) and executive_job_contract_valid(prep) and executive_job_contract_valid(triage) and executive_job_contract_valid(follow) and executive_job_needs_human_before_external_send(follow) and auth.authenticated and service_auth.authenticated and approval_product_contract_valid(approval_product)
