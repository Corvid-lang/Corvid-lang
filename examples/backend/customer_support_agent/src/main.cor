effect ticket_read:
    cost: $0.01
    trust: workspace
    data: customer

effect policy_search:
    cost: $0.01
    trust: grounded
    data: internal

effect support_ai:
    cost: $0.06
    trust: bounded
    data: customer

effect support_write:
    cost: $0.01
    trust: human_required
    data: customer

effect refund_write:
    cost: $0.02
    trust: human_required
    data: financial

public type SupportConfig:
    service: String
    connector_mode: String
    policy_required: Bool

public type SupportTicket:
    id: String
    tenant_id: String
    customer_fingerprint: String
    subject_fingerprint: String
    priority: String
    status: String

public type PolicyCitation:
    policy_id: String
    title_fingerprint: String
    section: String
    provenance_id: String

public type SupportTriage:
    ticket: SupportTicket
    category: String
    priority: String
    confidence: Float
    citation: PolicyCitation
    grounded: Bool

public type SupportDraftReply:
    ticket_id: String
    body_fingerprint: String
    citation: PolicyCitation
    status: String
    approval_label: String
    grounded: Bool

public type SupportReplySendRequest:
    tenant_id: String
    actor_id: String
    ticket_id: String
    body_fingerprint: String
    approval_id: String
    trace_id: String

public type SupportReplySendReceipt:
    ticket_id: String
    approval_id: String
    trace_id: String
    status: String

public type SupportRefundRequest:
    tenant_id: String
    actor_id: String
    ticket_id: String
    amount_cents: Int
    approval_id: String
    trace_id: String

public type SupportRefundReceipt:
    ticket_id: String
    approval_id: String
    trace_id: String
    status: String

public type SupportSlaJob:
    id: String
    tenant_id: String
    ticket_id: String
    due_at: String
    status: String
    replay_key: String

public type SupportEvalDashboard:
    grounded_replies: Int
    approval_gated_writes: Int
    sla_jobs: Int
    eval_passes: Int

tool send_support_reply(req: SupportReplySendRequest) -> SupportReplySendReceipt dangerous uses support_write
tool issue_support_refund(req: SupportRefundRequest) -> SupportRefundReceipt dangerous uses refund_write

public @replayable
agent support_config() -> SupportConfig:
    return SupportConfig("customer_support_agent", "mock", true)

public @replayable
agent demo_ticket() -> SupportTicket uses ticket_read:
    return SupportTicket("ticket-1", "tenant-1", "sha256:customer-demo", "sha256:subject-demo", "high", "open")

public @replayable
agent demo_policy_citation() -> PolicyCitation uses policy_search:
    return PolicyCitation("policy-refund-1", "sha256:refund-policy", "refund.window", "policy:refund:window")

public @replayable
agent triage_ticket_mock() -> SupportTriage uses ticket_read, policy_search, support_ai:
    ticket = demo_ticket()
    citation = demo_policy_citation()
    return SupportTriage(ticket, "refund_request", ticket.priority, 0.9, citation, citation.provenance_id != "")

public @replayable
agent draft_policy_grounded_reply_mock() -> SupportDraftReply uses ticket_read, policy_search, support_ai:
    triage = triage_ticket_mock()
    return SupportDraftReply(triage.ticket.id, "sha256:support-draft", triage.citation, "drafted", "SendSupportReply", triage.grounded)

public @replayable
agent support_triage_contract_valid(reply: SupportDraftReply) -> Bool:
    return reply.grounded and reply.citation.provenance_id != "" and reply.approval_label == "SendSupportReply" and reply.status == "drafted"

agent execute_approved_support_reply(req: SupportReplySendRequest) -> SupportReplySendReceipt uses support_write:
    approve SendSupportReply(req)
    return send_support_reply(req)

agent execute_approved_support_refund(req: SupportRefundRequest) -> SupportRefundReceipt uses refund_write:
    approve IssueSupportRefund(req)
    return issue_support_refund(req)

public @replayable
agent support_sla_job() -> SupportSlaJob:
    ticket = demo_ticket()
    return SupportSlaJob("sla-1", ticket.tenant_id, ticket.id, "2026-04-29T18:00:00Z", "scheduled", "support:sla:ticket-1")

public @replayable
agent support_eval_dashboard() -> SupportEvalDashboard:
    return SupportEvalDashboard(1, 2, 1, 4)

public @replayable
agent support_ops_contract_valid(dashboard: SupportEvalDashboard, sla: SupportSlaJob) -> Bool:
    return dashboard.grounded_replies >= 1 and dashboard.approval_gated_writes == 2 and dashboard.sla_jobs == 1 and sla.replay_key == "support:sla:ticket-1"

server customer_support_agent_api:
    route GET "/config" -> json SupportConfig:
        return support_config()
    route GET "/tickets/triage/mock" -> json SupportTriage uses ticket_read, policy_search, support_ai:
        return triage_ticket_mock()
    route GET "/replies/draft/mock" -> json SupportDraftReply uses ticket_read, policy_search, support_ai:
        return draft_policy_grounded_reply_mock()
    route GET "/sla/jobs/mock" -> json SupportSlaJob:
        return support_sla_job()
    route GET "/eval/dashboard/mock" -> json SupportEvalDashboard:
        return support_eval_dashboard()
    route POST "/replies/send" body SupportReplySendRequest -> json SupportReplySendReceipt uses support_write:
        return execute_approved_support_reply(body)
    route POST "/refunds/issue" body SupportRefundRequest -> json SupportRefundReceipt uses refund_write:
        return execute_approved_support_refund(body)

agent main() -> Bool:
    reply = draft_policy_grounded_reply_mock()
    dashboard = support_eval_dashboard()
    sla = support_sla_job()
    return support_triage_contract_valid(reply) and support_ops_contract_valid(dashboard, sla)
