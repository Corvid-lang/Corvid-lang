effect transfer_money:
    cost: $0.05
    trust: human_required
    reversible: false
    data: financial

type RefundRequest:
    order_id: String
    amount: Float
    reason: String

tool issue_refund(req: RefundRequest) -> String dangerous uses transfer_money

agent auth_bypass_refund(req: RefundRequest) -> String uses transfer_money:
    return issue_refund(req)
