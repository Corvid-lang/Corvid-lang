# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Pick a model. Anthropic models start with `claude-`; OpenAI with
# `gpt-`/`o1-`/`o3-`/`o4-`. The `corvid` CLI auto-routes by prefix.
CORVID_MODEL=gpt-4o-mini

# Provider keys. Set the one matching your CORVID_MODEL. Both can be set.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
