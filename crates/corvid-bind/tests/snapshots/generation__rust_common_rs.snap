#[derive(Debug)]
pub enum CorvidError {
    Load(String),
    DescriptorDrift(DescriptorDrift),
    ApprovalRequired(ApprovalRequest),
    ApprovalDenied(ApprovalRequest),
    BadArgs(String),
    UnsupportedSignature(String),
    BudgetExceeded(String),
    Runtime(String),
    Decode(String),
}

impl fmt::Display for CorvidError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            Self::Load(message) => write!(f, "load error: {message}"),
            Self::DescriptorDrift(err) => err.fmt(f),
            Self::ApprovalRequired(request) => write!(f, "approval required for `{}`", request.site_name),
            Self::ApprovalDenied(request) => write!(f, "approval denied for `{}`", request.site_name),
            Self::BadArgs(message) => write!(f, "bad args: {message}"),
            Self::UnsupportedSignature(message) => write!(f, "unsupported signature: {message}"),
            Self::BudgetExceeded(message) => write!(f, "budget exceeded: {message}"),
            Self::Runtime(message) => write!(f, "runtime error: {message}"),
            Self::Decode(message) => write!(f, "decode error: {message}"),
        }
    }
}

