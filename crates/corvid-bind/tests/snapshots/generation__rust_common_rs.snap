#[derive(Debug, Clone)]
pub struct Grounded<T> {
    payload: T,
    library: Arc<Library>,
    handle: u64,
}

impl<T> Grounded<T> {
    pub(crate) fn new(payload: T, library: Arc<Library>, handle: u64) -> Self {
        Self {
            payload,
            library,
            handle,
        }
    }

    pub fn payload(&self) -> &T {
        &self.payload
    }

    pub fn provenance(&self) -> GroundedProvenance<'_, T> {
        GroundedProvenance { grounded: self }
    }
}

impl<T> Drop for Grounded<T> {
    fn drop(&mut self) {
        if self.handle == 0 {
            return;
        }
        unsafe {
            if let Ok(symbol) =
                self.library.get::<unsafe extern "C" fn(u64)>(b"corvid_grounded_release")
            {
                symbol(self.handle);
            }
        }
        self.handle = 0;
    }
}

pub struct GroundedProvenance<'a, T> {
    grounded: &'a Grounded<T>,
}

impl<'a, T> GroundedProvenance<'a, T> {
    pub fn confidence(&self) -> f64 {
        unsafe {
            let symbol: Symbol<unsafe extern "C" fn(u64) -> f64> = self
                .grounded
                .library
                .get(b"corvid_grounded_confidence")
                .expect("resolve corvid_grounded_confidence");
            symbol(self.grounded.handle)
        }
    }

    pub fn sources(&self) -> CorvidResult<Vec<String>> {
        unsafe {
            let symbol: Symbol<
                unsafe extern "C" fn(u64, *mut *const c_char, usize) -> i32,
            > = self
                .grounded
                .library
                .get(b"corvid_grounded_sources")
                .map_err(|err| CorvidError::Load(err.to_string()))?;
            let count = symbol(self.grounded.handle, std::ptr::null_mut(), 0);
            if count < 0 {
                return Err(CorvidError::Runtime(
                    "runtime failed to enumerate grounded sources".to_string(),
                ));
            }
            let mut out = vec![std::ptr::null(); count as usize];
            let written = symbol(self.grounded.handle, out.as_mut_ptr(), out.len());
            if written < 0 {
                return Err(CorvidError::Runtime(
                    "runtime failed to read grounded sources".to_string(),
                ));
            }
            Ok(out
                .into_iter()
                .take(written as usize)
                .map(read_c_string_lossy)
                .collect())
        }
    }
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct Weak<T> {
    pub value: T,
}

pub(crate) fn read_c_string_lossy(ptr: *const c_char) -> String {
    if ptr.is_null() {
        return String::new();
    }
    unsafe { CStr::from_ptr(ptr) }.to_string_lossy().into_owned()
}

pub(crate) fn take_owned_c_string(
    library: &Arc<Library>,
    ptr: *const c_char,
) -> CorvidResult<String> {
    if ptr.is_null() {
        return Ok(String::new());
    }
    let value = unsafe { CStr::from_ptr(ptr) }
        .to_str()
        .map_err(|err| CorvidError::Decode(err.to_string()))?
        .to_string();
    unsafe {
        let free: Symbol<unsafe extern "C" fn(*const c_char)> = library
            .get(b"corvid_free_string")
            .map_err(|err| CorvidError::Load(err.to_string()))?;
        free(ptr);
    }
    Ok(value)
}

pub(crate) fn hex_bytes(bytes: &[u8]) -> String {
    let mut out = String::with_capacity(bytes.len() * 2);
    for byte in bytes {
        use std::fmt::Write as _;
        let _ = write!(&mut out, "{byte:02x}");
    }
    out
}
