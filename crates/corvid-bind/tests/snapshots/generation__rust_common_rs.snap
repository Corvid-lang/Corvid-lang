#[derive(Debug, Clone)]
pub struct Client {
    pub(crate) library: Arc<Library>,
}

impl Client {
    pub fn load(path: impl AsRef<Path>) -> CorvidResult<Self> {
        let library = unsafe { Library::new(path.as_ref()) }
            .map_err(|err| CorvidError::Load(err.to_string()))?;
        let client = Self {
            library: Arc::new(library),
        };
        client.verify_descriptor_hash()?;
        Ok(client)
    }

    pub fn catalog(&self) -> crate::catalog::Catalog<'_> {
        crate::catalog::Catalog::new(self)
    }

    pub(crate) fn verify_descriptor_hash(&self) -> CorvidResult<()> {
        let actual = self.descriptor_hash_hex()?;
        if actual != DESCRIPTOR_HASH_HEX {
            return Err(CorvidError::DescriptorDrift(DescriptorDrift {
                expected: DESCRIPTOR_HASH_HEX.to_string(),
                actual,
            }));
        }
        Ok(())
    }

    pub(crate) fn descriptor_hash_hex(&self) -> CorvidResult<String> {
        unsafe {
            let symbol: Symbol<unsafe extern "C" fn(*mut u8)> = self
                .library
                .get(b"corvid_abi_descriptor_hash")
                .map_err(|err| CorvidError::Load(err.to_string()))?;
            let mut bytes = [0u8; 32];
            symbol(bytes.as_mut_ptr());
            Ok(hex_bytes(&bytes))
        }
    }

    pub(crate) fn call_json_agent_once<Ret: DeserializeOwned>(
        &self,
        agent_name: &str,
        args_json: &str,
    ) -> CorvidResult<CallAttempt<Ret>> {
        unsafe {
            let call: unsafe extern "C" fn(
                *const c_char,
                *const c_char,
                usize,
                *mut *mut c_char,
                *mut usize,
                *mut u64,
                *mut CorvidApprovalRequiredRaw,
            ) -> i32 = *self
                .library
                .get(b"corvid_call_agent")
                .map_err(|err| CorvidError::Load(err.to_string()))?;
            let free_result: unsafe extern "C" fn(*mut c_char) = *self
                .library
                .get(b"corvid_free_result")
                .map_err(|err| CorvidError::Load(err.to_string()))?;

            let agent_name_c = CString::new(agent_name)
                .map_err(|err| CorvidError::BadArgs(err.to_string()))?;
            let args_json = CString::new(args_json)
                .map_err(|err| CorvidError::BadArgs(err.to_string()))?;
            let mut result_ptr = std::ptr::null_mut();
            let mut result_len = 0usize;
            let mut observation_handle = 0u64;
            let mut approval = CorvidApprovalRequiredRaw {
                site_name: std::ptr::null(),
                predicate_json: std::ptr::null(),
                args_json: std::ptr::null(),
                rationale_prompt: std::ptr::null(),
            };
            let status = call(
                agent_name_c.as_ptr(),
                args_json.as_ptr(),
                args_json.as_bytes().len(),
                &mut result_ptr,
                &mut result_len,
                &mut observation_handle,
                &mut approval,
            );

            let result_json = if result_ptr.is_null() {
                None
            } else {
                let slice = std::slice::from_raw_parts(result_ptr as *const u8, result_len);
                let text = String::from_utf8(slice.to_vec())
                    .map_err(|err| CorvidError::Decode(err.to_string()))?;
                free_result(result_ptr);
                Some(text)
            };

            match status {
                CORVID_CALL_OK => {
                    let observation = Observation::new(self.library.clone(), observation_handle);
                    let payload = serde_json::from_str::<Ret>(
                        result_json.as_deref().unwrap_or("null"),
                    )
                    .map_err(|err| CorvidError::Decode(err.to_string()))?;
                    Ok(CallAttempt::Completed((payload, observation)))
                }
                CORVID_CALL_APPROVAL_REQUIRED => {
                    self.release_observation_handle(observation_handle);
                    let request = ApprovalRequest::from_raw(&approval);
                    Ok(CallAttempt::ApprovalRequired(request))
                }
                CORVID_CALL_AGENT_NOT_FOUND => {
                    self.release_observation_handle(observation_handle);
                    Err(CorvidError::Runtime(format!(
                        "agent `{agent_name}` not found"
                    )))
                }
                CORVID_CALL_BAD_ARGS => {
                    self.release_observation_handle(observation_handle);
                    Err(CorvidError::BadArgs(
                        result_json.unwrap_or_else(|| "runtime rejected arguments".to_string()),
                    ))
                }
                CORVID_CALL_UNSUPPORTED_SIG => {
                    self.release_observation_handle(observation_handle);
                    Err(CorvidError::UnsupportedSignature(
                        result_json.unwrap_or_else(|| "runtime rejected unsupported signature".to_string()),
                    ))
                }
                CORVID_CALL_BUDGET_EXCEEDED => {
                    self.release_observation_handle(observation_handle);
                    Err(CorvidError::BudgetExceeded(
                        result_json.unwrap_or_else(|| "runtime budget exceeded".to_string()),
                    ))
                }
                CORVID_CALL_RUNTIME_ERROR => {
                    self.release_observation_handle(observation_handle);
                    Err(CorvidError::Runtime(
                        result_json.unwrap_or_else(|| "runtime error".to_string()),
                    ))
                }
                other => {
                    self.release_observation_handle(observation_handle);
                    Err(CorvidError::Runtime(format!(
                        "runtime returned unknown call status {other}"
                    )))
                }
            }
        }
    }

    pub(crate) fn mark_preapproved_request(&self, site_name: &str, args_json: &str) -> CorvidResult<()> {
        unsafe {
            let mark: unsafe extern "C" fn(*const c_char, *const c_char, usize) -> bool = *self
                .library
                .get(b"corvid_mark_preapproved_request")
                .map_err(|err| CorvidError::Load(err.to_string()))?;
            let site_name = CString::new(site_name)
                .map_err(|err| CorvidError::BadArgs(err.to_string()))?;
            let args_json = CString::new(args_json)
                .map_err(|err| CorvidError::BadArgs(err.to_string()))?;
            if mark(site_name.as_ptr(), args_json.as_ptr(), args_json.as_bytes().len()) {
                Ok(())
            } else {
                Err(CorvidError::Runtime(
                    "runtime rejected preapproved approval request".to_string(),
                ))
            }
        }
    }

    fn release_observation_handle(&self, handle: u64) {
        if handle == 0 {
            return;
        }
        unsafe {
            if let Ok(symbol) =
                self.library.get::<unsafe extern "C" fn(u64)>(b"corvid_observation_release")
            {
                symbol(handle);
            }
        }
    }
}

