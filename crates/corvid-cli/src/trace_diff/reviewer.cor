# The `corvid trace-diff` PR behavior reviewer.
#
# This file ships inside the Corvid CLI (embedded via `include_str!`)
# and is compiled at runtime when a user invokes
# `corvid trace-diff <base-sha> <head-sha> <path>`. The reviewer
# takes two pre-digested agent-summary descriptors — one from the
# base commit, one from the head — plus a pre-digested trace-replay
# impact summary (empty when `--traces` wasn't supplied), and
# produces a markdown PR behavior receipt.
#
# Why the reviewer is a Corvid program, not a Rust function:
#
# Corvid's thesis is that AI-native governance is a first-class
# programming domain with compile-time guarantees. If the flagship
# PR-review tool lived in Rust, we would be shipping the governance
# layer for our own language in the host language — the same
# shortcut Python would make shipping its linter in bash. The
# reviewer is in Corvid so that the tool itself is effect-bounded,
# @deterministic, and dogfoods the language on a real-world
# orchestration problem. Users can read, fork, and extend it.
#
# Scope landed:
#
#   21-inv-H-1 (static algebra diff):
#     - Detect agents added / removed between base and head.
#     - Flag trust-tier changes (String comparison).
#     - Flag `@dangerous` / `@replayable` transitions.
#
#   21-inv-H-2 (counterfactual replay impact):
#     - Extra receipt section counting, over a user-supplied
#       trace corpus, how many traces newly diverge under head.
#     - Impact is the absolute count and a "newly-diverged path
#       list" — the reviewer is `@deterministic` so this
#       survives identical across CI reruns.
#
#   21-inv-H-3 (structured approval + provenance drill-down):
#     - Per-agent approval labels: detect added / removed
#       `approve` call sites, lowered `required_tier`, and
#       `reversibility` transitions to `irreversible`.
#     - Per-agent provenance: detect `returns_grounded`
#       transitions, added / removed `grounded_param_deps`.
#
#   21-inv-H-4 (structured narrative summary):
#     - Top-of-receipt one-to-three-sentence prose paragraph
#       generated by a `summarise_diff` prompt, with every
#       specific change cited by its canonical delta key.
#     - `review_pr` takes the already-validated `ReceiptNarrative`
#       as an input; the deterministic layer renders it and falls
#       back to boilerplate when the narrative is empty (either
#       because `--narrative=off`, no adapter was configured, or
#       Rust rejected the LLM's output on citation-validation).
#     - `review_pr` stays `@deterministic`: identical inputs
#       always produce byte-identical output. The narrative's
#       non-determinism lives entirely in the separate
#       `summarise_diff` prompt invocation Rust owns.
#
# The reviewer's structural layer (`review_pr`, `render_*`,
# `find_label`, `label_present`, `dep_present`) is `@deterministic` —
# no LLM calls, no approval gates, no tool dispatch. The
# `summarise_diff` prompt is the only non-deterministic surface and
# only fires when a runtime adapter is configured.
#
# Not yet in the reviewer (deferred to follow-up slices):
#
#   - Cost/budget deltas. Needs a Float→String primitive; the
#     reviewer will render `cost/call` changes once the language
#     has one.
#   - Structured 22-E predicate-JSON AST diff (needs typed JSON
#     in Corvid; different language-surface work).
#   - `Grounded<ReceiptNarrative>` upgrade: the narrative should
#     carry type-level provenance. Blocked on 22-F (`Grounded<T>`
#     crossing the FFI boundary). Lands as a follow-up after 22-F.

type ApprovalLabelSummary:
    label: String
    required_tier: String
    reversibility: String

type ApprovalContractSummary:
    required: Bool
    labels: List<ApprovalLabelSummary>

type ProvenanceSummary:
    returns_grounded: Bool
    grounded_param_deps: List<String>

type OwnershipSlotSummary:
    position: String
    ownership: String

type AgentSummary:
    name: String
    trust_tier: String
    is_dangerous: Bool
    is_replayable: Bool
    param_ownerships: List<OwnershipSlotSummary>
    return_ownership: String
    approval: ApprovalContractSummary
    provenance: ProvenanceSummary

type Descriptor:
    agents: List<AgentSummary>

# Counterfactual replay impact — the 21-inv-H-2 section of the
# receipt. Every trace in a user-supplied corpus is replayed
# against base and head; the Rust CLI digests the per-trace
# verdicts into pre-formatted strings (Corvid does not yet have
# an Int→String primitive — a follow-up language slice will close
# that gap). The Corvid reviewer owns:
#
#   - whether the section is rendered at all (`has_traces`);
#   - where it appears in the receipt;
#   - which narrative lines accompany the counts;
#   - the newly-divergent trace-path list.
#
# `has_traces: Bool = false` is the "no trace corpus was supplied"
# sentinel — the reviewer renders nothing for that case to keep
# slice-1 receipts stable for callers that didn't opt in to
# `--traces`.
type TraceImpact:
    has_traces: Bool
    any_newly_diverged: Bool
    summary_line: String
    impact_percentage: String
    newly_diverged_paths: List<String>

# A single algebraic delta between base and head, addressable by
# a canonical key the narrative prompt cites verbatim. `key` is
# dot-separated category, colon-separated variadic args — e.g.
# "agent.added:refund_bot",
# "agent.approval.label_added:refund_bot:SendNotice",
# "agent.provenance.grounded_gained:explain". `summary` is the
# short human-readable phrase the prompt uses as context.
type DeltaRecord:
    key: String
    summary: String

# The complete set of algebraic deltas. Rust computes this from
# base + head before the prompt call and before the reviewer call;
# the same set becomes both the prompt's structured input and the
# allow-list for citation validation.
type DiffSummary:
    records: List<DeltaRecord>

# A single citation the LLM narrative attaches to a specific
# phrase. `delta_key` must be one of the `DeltaRecord.key` values
# Rust passed in; Rust rejects the narrative otherwise.
type DeltaCitation:
    delta_key: String

# The prose-summary surface Rust validates before handing it to
# `review_pr`. When the narrative is rejected (unknown citation
# key, duplicate key, empty citations with non-empty body), Rust
# passes an empty `ReceiptNarrative("", [])` and the reviewer
# renders the H-3 boilerplate header instead.
type ReceiptNarrative:
    body: String
    citations: List<DeltaCitation>

# Non-deterministic prose summary of the algebraic diff.
# Invoked by Rust only when an LLM adapter is configured and the
# `--narrative` flag is on (or `auto` with an adapter). The
# prompt's output is re-validated by Rust before it reaches
# `review_pr`.
prompt summarise_diff(delta: DiffSummary) -> ReceiptNarrative:
    """
    You are writing the one-paragraph top-of-receipt summary for a
    Corvid trace-diff PR review. The receipt is consumed by a human
    code reviewer.

    Write one to three short factual sentences describing the
    behavioural changes in the delta list. Be neutral; do not
    speculate about intent or motivation. Do not mention anything
    not present in the delta list.

    Cite every specific change you reference by adding an entry to
    `citations` whose `delta_key` is the exact `DeltaRecord.key`
    from the input. If you mention two changes in one sentence,
    add both keys to `citations`.

    If the delta list is empty, return an empty body and an empty
    citations list.

    Rules:
    - Do not invent delta keys. Only cite keys that appear in the
      input.
    - Do not cite the same key twice.
    - Do not leave a non-empty body with an empty citations list.
    """

# Find the `ApprovalLabelSummary` for a given label name in a list,
# or return a sentinel summary with empty strings when absent. The
# sentinel approach lets the diff logic treat "not present" and
# "present with defaults" uniformly and keeps the `@deterministic`
# guarantee without needing Option-method support.
@deterministic
agent find_label(labels: List<ApprovalLabelSummary>, name: String) -> ApprovalLabelSummary:
    sentinel = ApprovalLabelSummary("", "", "")
    found = sentinel
    for l in labels:
        if l.label == name:
            found = l
    return found

@deterministic
agent label_present(labels: List<ApprovalLabelSummary>, name: String) -> Bool:
    present = false
    for l in labels:
        if l.label == name:
            present = true
    return present

# Render the approval-contract drill-down for one agent, returning
# the Markdown lines describing any change (empty String when the
# contracts are identical).
@deterministic
agent render_approval_diff_for_agent(name: String, base: ApprovalContractSummary, head: ApprovalContractSummary) -> String:
    lines = ""

    # Pass 1: labels present on base. Either removed on head, or
    # changed in required_tier / reversibility.
    for b in base.labels:
        in_head = label_present(head.labels, b.label)
        if not in_head:
            lines = lines + "- approve site `" + b.label + "` removed\n"
        else:
            h = find_label(head.labels, b.label)
            if b.required_tier != h.required_tier:
                lines = lines + "- approve site `" + b.label + "` required-tier: `" + b.required_tier + "` -> `" + h.required_tier + "`\n"
            if b.reversibility != h.reversibility:
                if h.reversibility == "irreversible":
                    lines = lines + "- approve site `" + b.label + "` became irreversible\n"
                else:
                    lines = lines + "- approve site `" + b.label + "` reversibility: `" + b.reversibility + "` -> `" + h.reversibility + "`\n"

    # Pass 2: labels added on head.
    for h in head.labels:
        in_base = label_present(base.labels, h.label)
        if not in_base:
            lines = lines + "- approve site `" + h.label + "` added (required-tier: `" + h.required_tier + "`)\n"

    if lines == "":
        return ""
    return "### `" + name + "` approval contract changed\n" + lines + "\n"

@deterministic
agent dep_present(deps: List<String>, name: String) -> Bool:
    present = false
    for d in deps:
        if d == name:
            present = true
    return present

@deterministic
agent ownership_slot_present(slots: List<OwnershipSlotSummary>, position: String) -> Bool:
    present = false
    for slot in slots:
        if slot.position == position:
            present = true
    return present

@deterministic
agent find_ownership_slot(slots: List<OwnershipSlotSummary>, position: String) -> OwnershipSlotSummary:
    sentinel = OwnershipSlotSummary("", "")
    found = sentinel
    for slot in slots:
        if slot.position == position:
            found = slot
    return found

@deterministic
agent render_ownership_diff_for_agent(name: String, base: AgentSummary, head: AgentSummary) -> String:
    lines = ""

    if base.return_ownership != head.return_ownership:
        lines = lines + "- return ownership: `" + base.return_ownership + "` -> `" + head.return_ownership + "`\n"

    for b in base.param_ownerships:
        if ownership_slot_present(head.param_ownerships, b.position):
            h = find_ownership_slot(head.param_ownerships, b.position)
            if b.ownership != h.ownership:
                lines = lines + "- argument #" + b.position + " ownership: `" + b.ownership + "` -> `" + h.ownership + "`\n"

    if lines == "":
        return ""
    return "### `" + name + "` extern ownership changed\n" + lines + "\n"

# Render the provenance drill-down for one agent. Empty String when
# grounded status + dependency list are identical.
@deterministic
agent render_provenance_diff_for_agent(name: String, base: ProvenanceSummary, head: ProvenanceSummary) -> String:
    lines = ""

    if base.returns_grounded != head.returns_grounded:
        if head.returns_grounded:
            lines = lines + "- return value gained `Grounded<T>` provenance\n"
        else:
            lines = lines + "- return value lost `Grounded<T>` provenance\n"

    for b in base.grounded_param_deps:
        in_head = dep_present(head.grounded_param_deps, b)
        if not in_head:
            lines = lines + "- grounded dependency on `" + b + "` removed\n"

    for h in head.grounded_param_deps:
        in_base = dep_present(base.grounded_param_deps, h)
        if not in_base:
            lines = lines + "- grounded dependency on `" + h + "` added\n"

    if lines == "":
        return ""
    return "### `" + name + "` provenance changed\n" + lines + "\n"

# Render the algebra-diff section of the receipt.
@deterministic
agent render_algebra_diff(base: Descriptor, head: Descriptor) -> String:
    body = ""
    any_changes = false

    for b in base.agents:
        in_head = false
        for h in head.agents:
            if b.name == h.name:
                in_head = true
                if b.trust_tier != h.trust_tier:
                    body = body + "### `" + b.name + "` trust changed\n"
                    body = body + "- base: `" + b.trust_tier + "`\n"
                    body = body + "- head: `" + h.trust_tier + "`\n\n"
                    any_changes = true
                if b.is_dangerous != h.is_dangerous:
                    if h.is_dangerous:
                        body = body + "### `" + b.name + "` became `@dangerous`\n\n"
                    else:
                        body = body + "### `" + b.name + "` no longer `@dangerous`\n\n"
                    any_changes = true
                if b.is_replayable != h.is_replayable:
                    if h.is_replayable:
                        body = body + "### `" + b.name + "` gained `@replayable`\n\n"
                    else:
                        body = body + "### `" + b.name + "` lost `@replayable`\n\n"
                    any_changes = true
                approval_section = render_approval_diff_for_agent(b.name, b.approval, h.approval)
                if approval_section != "":
                    body = body + approval_section
                    any_changes = true
                provenance_section = render_provenance_diff_for_agent(b.name, b.provenance, h.provenance)
                if provenance_section != "":
                    body = body + provenance_section
                    any_changes = true
                ownership_section = render_ownership_diff_for_agent(b.name, b, h)
                if ownership_section != "":
                    body = body + ownership_section
                    any_changes = true
        if not in_head:
            body = body + "### Removed: `" + b.name + "`\n\n"
            any_changes = true

    for h in head.agents:
        in_base = false
        for b in base.agents:
            if b.name == h.name:
                in_base = true
        if not in_base:
            body = body + "### Added: `" + h.name + "`\n\n"
            any_changes = true

    if not any_changes:
        body = body + "_No algebraic changes detected along the exported surface._\n\n"

    return body

# Render the counterfactual-replay-impact section (21-inv-H-2).
# Empty string when `has_traces == false`, so callers that didn't
# opt into `--traces` see zero footprint from this section.
@deterministic
agent render_trace_impact(impact: TraceImpact) -> String:
    if not impact.has_traces:
        return ""
    body = "## Counterfactual Replay Impact\n\n"
    body = body + impact.summary_line + "\n\n"
    if impact.any_newly_diverged:
        body = body + "**Impact:** " + impact.impact_percentage + " of traces would have newly diverged under this PR.\n\n"
        body = body + "### Newly divergent under head\n\n"
        for p in impact.newly_diverged_paths:
            body = body + "- `" + p + "`\n"
        body = body + "\n"
    else:
        body = body + "No traces newly diverge under this PR.\n\n"
    return body

# Produce the full PR behavior receipt. `@deterministic`: the same
# four inputs always produce byte-identical output, so CI
# pipelines can memoize the receipt on (base-sha, head-sha,
# traces-hash, narrative-hash) without drift across reruns. The
# narrative's own non-determinism is encapsulated in the separate
# `summarise_diff` prompt Rust invokes before `review_pr`; by the
# time we get here the narrative is either a validated prose
# paragraph or the empty sentinel (`body == ""`), and both cases
# render deterministically.
@deterministic
agent review_pr(base: Descriptor, head: Descriptor, impact: TraceImpact, narrative: ReceiptNarrative) -> String:
    body = "# PR Behavior Receipt\n\n"
    if narrative.body != "":
        body = body + narrative.body + "\n\n"
    else:
        body = body + "Comparing base vs. head along Corvid's effect algebra.\n\n"
    body = body + render_algebra_diff(base, head)
    body = body + render_trace_impact(impact)
    return body
